<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:clickable="true"
    android:focusable="true"
    android:keepScreenOn="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#EAB308"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/lock_screen_title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/lock_inviolable_hint"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/overlay_attempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textColor="#FCA5A5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/overlay_pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#1A1A1A"
            android:gravity="center"
            android:hint="@string/hint_pin"
            android:inputType="numberPassword"
            android:maxLength="12"
            android:padding="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="22sp"
            android:importantForAutofill="no"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:cursorVisible="true"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/overlay_unlock"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#FFFFFF"
            android:text="@string/btn_unlock"
            android:textColor="#000000"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/lock_layer_note"
            android:textColor="#444444"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
