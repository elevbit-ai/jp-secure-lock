<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#EAB308"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_lock_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/lock_screen_title"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/header_extras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/headline"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_creator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_admin_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="#FCA5A5" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:padding="12dp"
            android:background="#1A1A1A"
            android:textColor="#F5F5F5"
            android:textSize="13sp" />

        <!-- SETUP -->
        <LinearLayout
            android:id="@+id/panel_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_help"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_lock_level"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EAB308"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_enable_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_enable_admin"
                android:backgroundTint="#7F1D1D"
                android:textColor="#FECACA"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_overlay"
                android:backgroundTint="#3F1D1D"
                android:textColor="#FECACA"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_home"
                android:backgroundTint="#1D2A3F"
                android:textColor="#BFDBFE"
                android:layout_marginBottom="10dp" />

            <CheckBox
                android:id="@+id/cb_antitheft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/cb_antitheft"
                android:textColor="#FCA5A5"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_setup_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_pin"
                android:inputType="numberPassword"
                android:maxLength="12"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="14dp" />

            <EditText
                android:id="@+id/et_setup_pin2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_pin2"
                android:inputType="numberPassword"
                android:maxLength="12"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="14dp" />

            <EditText
                android:id="@+id/et_secret"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_secret"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="14dp" />

            <Button
                android:id="@+id/btn_activate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_activate"
                android:backgroundTint="#EAB308"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- UNLOCK — tela principal do bloqueador -->
        <LinearLayout
            android:id="@+id/panel_unlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/lock_enter_pin"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_attempts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FCA5A5"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_unlock_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_pin"
                android:inputType="numberPassword"
                android:maxLength="12"
                android:gravity="center"
                android:textSize="22sp"
                android:letterSpacing="0.3"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="18dp"
                android:imeOptions="actionDone" />

            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_unlock"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="@string/lock_no_exit_hint"
                android:textColor="#555555"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- UNLOCKED SESSION -->
        <LinearLayout
            android:id="@+id/panel_unlocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unlocked_help"
                android:textColor="#86EFAC"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_unlocked_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="14dp"
                android:background="#0F1F14"
                android:textColor="#E5E5E5"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_relock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/btn_relock"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_release"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_release"
                android:backgroundTint="#EAB308"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- WIPED / RECOVER -->
        <LinearLayout
            android:id="@+id/panel_wiped"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wiped_help"
                android:textColor="#FCA5A5"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_recovery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_recovery"
                android:inputType="textCapCharacters"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="14dp" />

            <EditText
                android:id="@+id/et_new_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_new_pin"
                android:inputType="numberPassword"
                android:maxLength="12"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#141414"
                android:padding="14dp" />

            <Button
                android:id="@+id/btn_recover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_recover"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- RELEASED -->
        <LinearLayout
            android:id="@+id/panel_released"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/released_help"
                android:textColor="#A3A3A3"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_new_setup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_new_setup"
                android:backgroundTint="#EAB308"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- WIPE ANIM -->
        <LinearLayout
            android:id="@+id/panel_wipe_anim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wipe_anim_title"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/wipe_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#EF4444" />

            <TextView
                android:id="@+id/tv_wipe_log"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="10dp"
                android:background="#0A0A0A"
                android:padding="12dp"
                android:textColor="#4ADE80"
                android:typeface="monospace"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/legal_note"
            android:textColor="#444444"
            android:textSize="10sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</ScrollView>
